@model IEnumerable<E_Commerce.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div id="page-content">
    <!--Breadcrumbs-->
    <div class="breadcrumbs-wrapper">
        <div class="container">
            <div class="breadcrumbs">
                <a asp-area="" asp-controller="Home" asp-action="Index" title="Back to the home page">Home</a>
                <span aria-hidden="true">|</span>
                <span>Categories</span>
            </div>
        </div>
    </div>
    <!--End Breadcrumbs-->

    <div class="container">
        <div class="page-title text-center mb-5">
            <h1>Our Collections</h1>
        </div>

        <!--Category Masonary Grid-->
        <div class="collection-banners style2">
            <div class="grid-masonary collection-page-grid style2">
                <div class="grid-sizer col-sm-6 col-md-4 col-lg-4"></div>
                <div class="row">
                    @foreach (var item in Model)
                    {
                        <!-- نتحقق فقط من الفئات غير المحذوفة إذا كنتِ ترغبين في إخفائها -->
                        @if (item.IsDeleted != true)
                        {
                            <div class="col-12 col-sm-6 col-md-4 col-lg-4 collection-page-item mb-4">
                                <div class="collection-grid-item">
                                    <div class="img">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="collection-grid-item__link">
                                            <img class="blur-up lazyload"
                                                 src="@item.ImagePath"
                                                 alt="@item.Name"
                                                 style="height:350px; width:100%; object-fit:cover;" />

                                            <span class="details">
                                                <span class="inner">
                                                    <span class="collection-grid-item__title">@item.Name</span>
                                                    <span class="counts">@item.Description</span>
                                                </span>
                                            </span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <!--End Category Masonary Grid-->
    </div>
</div>
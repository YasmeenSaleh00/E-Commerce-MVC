@model E_Commerce.Models.Order

@{
    ViewData["Title"] = $"Order #{Model.Id}";
    var badgeCss = Model.Status switch {
        E_Commerce.Models.OrderStatus.Pending    => "bg-warning text-dark",
        E_Commerce.Models.OrderStatus.Processing => "bg-info text-dark",
        E_Commerce.Models.OrderStatus.Shipped    => "bg-primary",
        E_Commerce.Models.OrderStatus.Delivered  => "bg-success",
        E_Commerce.Models.OrderStatus.Cancelled  => "bg-danger",
        _                                        => "bg-secondary"
    };
}

<div class="container py-5">
    <a asp-action="Dashboard" class="btn btn-outline-dark mb-4">
        <i class="bi bi-arrow-left me-1"></i>Back to My Orders
    </a>

    <div class="row g-4 justify-content-center">
        <div class="col-lg-8">

            <!-- Header -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h4 class="fw-bold mb-1">Order #@Model.Id</h4>
                            <div class="text-muted small">
                                Placed on @Model.OrderDate.ToLocalTime().ToString("MMMM dd, yyyy")
                            </div>
                        </div>
                        <span class="badge @badgeCss py-2 px-3 fs-6">@Model.Status</span>
                    </div>
                </div>
            </div>

            <!-- Items -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold py-3">Items Ordered</div>
                <div class="card-body p-0">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-center">Unit Price</th>
                                <th class="text-center">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">@item.ProductName</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-center">$@item.UnitPrice.ToString("0.00")</td>
                                    <td class="text-center">$@item.TotalPrice.ToString("0.00")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold ps-4">Total</td>
                                <td class="text-center fw-bold fs-5">$@Model.Total.ToString("0.00")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Shipping -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold py-3">Shipping Address</div>
                <div class="card-body">
                    <p class="mb-1 fw-semibold">@Model.ShippingFirstName @Model.ShippingLastName</p>
                    <p class="mb-1 text-muted">@Model.ShippingAddress</p>
                    <p class="mb-1 text-muted">@Model.ShippingCity, @Model.ShippingCountry @Model.ShippingPostalCode</p>
                    @if (!string.IsNullOrEmpty(Model.ShippingPhone))
                    {
                        <p class="mb-0 text-muted">@Model.ShippingPhone</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

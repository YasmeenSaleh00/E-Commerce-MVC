@model E_Commerce.Models.Brand

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card delete-card">
                <div class="delete-header">
                    <i class="bi bi-exclamation-triangle-fill fs-1 mb-2"></i>
                    <h2 class="mb-0">Delete Confirmation</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="warning-box">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Are you sure you want to permanently delete this brand? This action cannot be undone.
                    </div>

                    <div class="row align-items-center">
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <img src="@Model.ImageUrl" width="180" height="180" class="img-delete-preview" alt="Category Image" />
                        </div>

                        <div class="col-md-8">
                            <div class="info-label">Category Name</div>
                            <div class="info-value fw-bold">@Model.Name</div>


                            <div class="info-label">Created On</div>
                            <div class="info-value small">@Model.CreationDate?.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>

                    <hr class="my-4" style="opacity: 0.1;" />

                    <div class="d-flex justify-content-center gap-3">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger-custom">
                                <i class="bi bi-trash3 me-1"></i> Confirm Delete
                            </button>
                        </form>
                        <a asp-action="Index" class="btn btn-cancel">
                            Cancel & Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

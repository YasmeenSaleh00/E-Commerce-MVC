@model E_Commerce.Models.Brand

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card details-card">
                <div class="category-header">
                    <h2 class="mb-0">Brand Overview</h2>
                    <p class="mb-0 opacity-75">Detailed information about @Model.Name</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row">
                        <div class="col-md-5 mb-4 mb-md-0">
                            <div class="img-preview-container">
                                <img src="@Model.ImageUrl" alt="@Model.Name" style="width:100px" />
                            </div>
                        </div>

                        <div class="col-md-7 ps-md-5">
                            <div class="row">
                                <div class="col-12">
                                    <div class="info-label">Brand Name</div>
                                    <div class="info-value fw-bold text-dark">@Model.Name</div>
                                </div>

                           

                                <div class="col-6">
                                    <div class="info-label">Created At</div>
                                    <div class="info-value small">@Model.CreationDate?.ToString("dd MMM yyyy")</div>
                                </div>

                                <div class="col-6">
                                    <div class="info-label">Last Updated</div>
                                    <div class="info-value small">@(Model.ModifcationDate?.ToString("dd MMM yyyy") ?? "Never")</div>
                                </div>

                                <div class="col-12">
                                    <div class="info-label">Current Status</div>
                                    <div class="info-value border-0">
                                        @if (@Model.IsDeleted == true)
                                        {
                                            <span class="status-badge bg-danger bg-opacity-10 text-danger">
                                                <i class="bi bi-x-circle me-1"></i> Not Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge bg-success bg-opacity-10 text-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 d-flex gap-3">
                                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-edit shadow-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Edit Brand
                                </a>
                                <a asp-action="Index" class="btn btn-back">
                                    <i class="bi bi-arrow-left me-1"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

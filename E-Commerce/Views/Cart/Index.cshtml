@model E_Commerce.Models.ShoppingCart

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Shopping Cart</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.CartItems.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x" style="font-size:4rem; color:#ccc;"></i>
            <h4 class="mt-3 text-muted">Your cart is empty</h4>
            <a asp-controller="Products" asp-action="Index" class="btn btn-dark mt-3 px-4">Continue Shopping</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <table class="table mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Product</th>
                                    <th class="text-center">Price</th>
                                    <th class="text-center">Quantity</th>
                                    <th class="text-center">Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    var img = item.Product?.Images?.FirstOrDefault()?.ImageUrl;
                                    <tr>
                                        <td class="ps-4" style="min-width:220px;">
                                            <div class="d-flex align-items-center gap-3">
                                                @if (!string.IsNullOrEmpty(img))
                                                {
                                                    <img src="/@img.TrimStart('/')" alt="@item.Product.Name"
                                                         style="width:64px;height:64px;object-fit:cover;border-radius:8px;" />
                                                }
                                                else
                                                {
                                                    <div style="width:64px;height:64px;background:#f0f0f0;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                                        <i class="bi bi-image text-muted"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <div class="fw-semibold">@item.Product?.Name</div>
                                                    <small class="text-muted">@item.Product?.Category?.Name</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">$@item.Product?.Price.ToString("0.00")</td>
                                        <td class="text-center" style="width:160px;">
                                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center justify-content-center gap-2">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                        class="btn btn-outline-secondary btn-sm px-2">−</button>
                                                <span class="fw-bold" style="min-width:24px;text-align:center;">@item.Quantity</span>
                                                <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                        class="btn btn-outline-secondary btn-sm px-2">+</button>
                                            </form>
                                        </td>
                                        <td class="text-center fw-semibold">$@item.SubTotal.ToString("0.00")</td>
                                        <td class="text-center pe-3">
                                            <form asp-action="Remove" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <button type="submit" class="btn btn-link text-danger p-0" title="Remove">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark">
                        <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Order Summary</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal (@Model.TotalItems items)</span>
                            <span>$@Model.Total.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Shipping</span>
                            <span class="text-success">Free</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Total</span>
                            <span>$@Model.Total.ToString("0.00")</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-dark w-100 py-2">
                            Proceed to Checkout <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

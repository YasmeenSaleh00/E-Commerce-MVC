@model E_Commerce.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var mainImg = Model.Images?.FirstOrDefault()?.ImageUrl;
    var available = Model.ProductStatus == E_Commerce.Models.ProductStatus.Available;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-dark">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" class="text-dark">Shop</a></li>
        @if (Model.Category != null)
        {
            <li class="breadcrumb-item">
                <a asp-controller="Products" asp-action="FilterByCategory" asp-route-categoryId="@Model.CategoryId"
                   class="text-dark">@Model.Category.Name</a>
            </li>
        }
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row g-5 mb-5">
    <!-- Images -->
    <div class="col-lg-6">
        <div class="border rounded-3 overflow-hidden mb-3" style="height:420px;">
            @if (!string.IsNullOrEmpty(mainImg))
            {
                <img src="/@mainImg.TrimStart('/')" id="mainImage" alt="@Model.Name"
                     class="w-100 h-100" style="object-fit:cover;" />
            }
            else
            {
                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                    <i class="bi bi-image text-muted" style="font-size:4rem;"></i>
                </div>
            }
        </div>
        @if (Model.Images != null && Model.Images.Count > 1)
        {
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var image in Model.Images)
                {
                    <img src="/@image.ImageUrl.TrimStart('/')" alt="@Model.Name"
                         onclick="document.getElementById('mainImage').src=this.src"
                         class="border rounded cursor-pointer"
                         style="width:72px;height:72px;object-fit:cover;cursor:pointer;transition:border-color 0.2s;"
                         onmouseover="this.style.borderColor='#333'" onmouseout="this.style.borderColor=''" />
                }
            </div>
        }
    </div>

    <!-- Info -->
    <div class="col-lg-6">
        <div class="text-muted small mb-1">@Model.Category?.Name</div>
        <h2 class="fw-bold mb-2">@Model.Name</h2>

        @{
            var statusBadge = Model.ProductStatus switch {
                E_Commerce.Models.ProductStatus.Available => "bg-success",
                E_Commerce.Models.ProductStatus.OutOfStock => "bg-danger",
                E_Commerce.Models.ProductStatus.ComingSoon => "bg-info text-dark",
                _ => "bg-secondary"
            };
        }
        <span class="badge @statusBadge mb-3">@Model.ProductStatus</span>

        <div class="fs-2 fw-bold mb-3">$@Model.Price.ToString("0.00")</div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted mb-4">@Model.Description</p>
        }

        <div class="d-flex align-items-center gap-3 mb-3">
            <label class="fw-semibold">Quantity:</label>
            <div class="input-group" style="width:130px;">
                <button class="btn btn-outline-secondary" type="button" onclick="changeQty(-1)">−</button>
                <input type="number" id="qty" value="1" min="1" max="@Model.Quantity" class="form-control text-center" />
                <button class="btn btn-outline-secondary" type="button" onclick="changeQty(1)">+</button>
            </div>
            <span class="text-muted small">(@Model.Quantity in stock)</span>
        </div>

        @if (available)
        {
            <form asp-controller="Cart" asp-action="Add" method="post" class="mb-3">
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" name="quantity" id="formQty" value="1" />
                <button type="submit" class="btn btn-dark btn-lg px-5 w-100 w-sm-auto"
                        onclick="document.getElementById('formQty').value = document.getElementById('qty').value;">
                    <i class="bi bi-bag-plus me-2"></i>Add to Cart
                </button>
            </form>
        }
        else
        {
            <button class="btn btn-secondary btn-lg px-5 w-100" disabled>Unavailable</button>
        }

        <hr class="my-4" />
        <div class="d-flex gap-4 text-muted small">
            <span><i class="bi bi-truck me-1"></i>Free Shipping</span>
            <span><i class="bi bi-arrow-return-left me-1"></i>30-day Returns</span>
            <span><i class="bi bi-shield-check me-1"></i>Secure</span>
        </div>
    </div>
</div>

<!-- Related Products -->
@if (ViewBag.RelatedProducts != null)
{
    var related = (IEnumerable<E_Commerce.Models.Product>)ViewBag.RelatedProducts;
    @if (related.Any())
    {
        <section class="mt-2">
            <h4 class="fw-bold mb-4">You Might Also Like</h4>
            <div class="row g-4">
                @foreach (var rp in related)
                {
                    var rpImg = rp.Images?.FirstOrDefault()?.ImageUrl;
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100 product-card">
                            <div style="height:180px; overflow:hidden;">
                                @if (!string.IsNullOrEmpty(rpImg))
                                {
                                    <img src="/@rpImg.TrimStart('/')" alt="@rp.Name" class="w-100 h-100" style="object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body p-3">
                                <div class="fw-semibold small mb-1">
                                    <a asp-action="Details" asp-route-id="@rp.Id" class="text-dark text-decoration-none">@rp.Name</a>
                                </div>
                                <div class="fw-bold">$@rp.Price.ToString("0.00")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
}

<style>
    .product-card { transition: transform 0.2s; }
    .product-card:hover { transform: translateY(-3px); }
</style>

@section Scripts {
    <script>
        function changeQty(delta) {
            const input = document.getElementById('qty');
            const val = parseInt(input.value) + delta;
            const max = parseInt(input.max);
            input.value = Math.max(1, Math.min(val, max));
        }
    </script>
}

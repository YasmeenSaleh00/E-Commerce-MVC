@model IEnumerable<E_Commerce.Models.Product>

@{
    ViewData["Title"] = ViewBag.CategoryName ?? "Shop";
}

<div class="row g-4">
    <!-- Sidebar Filters -->
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm p-4 sticky-top" style="top:20px;">
            <h6 class="fw-bold mb-3">Filter Products</h6>
            <form asp-action="Index" method="get">
                <div class="mb-3">
                    <label class="form-label small text-muted text-uppercase fw-semibold">Search</label>
                    <input type="text" name="searchString" value="@ViewBag.SearchString"
                           class="form-control form-control-sm" placeholder="Product name..." />
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted text-uppercase fw-semibold">Category</label>
                    <select name="categoryId" class="form-select form-select-sm">
                        <option value="">All Categories</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in (IEnumerable<E_Commerce.Models.Category>)ViewBag.Categories)
                            {
                                if ((int?)ViewBag.CategoryId == cat.Id)
                                {
                                    <option value="@cat.Id" selected>@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-dark w-100 btn-sm">Apply Filters</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchString as string) || ViewBag.CategoryId != null)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 btn-sm mt-2">Clear</a>
                }
            </form>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">@(ViewBag.CategoryName ?? "All Products") <span class="text-muted fw-normal fs-6">(@Model.Count() items)</span></h4>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted border rounded-3">
                <i class="bi bi-search fs-1"></i>
                <p class="mt-2">No products found.</p>
                <a asp-action="Index" class="btn btn-outline-dark btn-sm">Clear Filters</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model)
                {
                    var img = product.Images?.FirstOrDefault()?.ImageUrl;
                    var available = product.ProductStatus == E_Commerce.Models.ProductStatus.Available;
                    <div class="col-6 col-md-4">
                        <div class="card border-0 shadow-sm h-100 product-card">
                            <div class="position-relative overflow-hidden" style="height:210px;">
                                @if (!string.IsNullOrEmpty(img))
                                {
                                    <img src="/@img.TrimStart('/')" alt="@product.Name"
                                         class="w-100 h-100" style="object-fit:cover; transition: transform 0.3s;" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <i class="bi bi-image text-muted fs-1"></i>
                                    </div>
                                }
                                @if (!available)
                                {
                                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                                         style="background:rgba(0,0,0,0.45);">
                                        <span class="badge bg-danger fs-6">@product.ProductStatus</span>
                                    </div>
                                }
                                @if (product.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">
                                        <i class="bi bi-star-fill me-1"></i>Featured
                                    </span>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <div class="text-muted" style="font-size:0.75rem;">@product.Category?.Name</div>
                                <h6 class="fw-semibold my-1 flex-grow-1" style="font-size:0.9rem;">
                                    <a asp-action="Details" asp-route-id="@product.Id"
                                       class="text-dark text-decoration-none">@product.Name</a>
                                </h6>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="fw-bold">$@product.Price.ToString("0.00")</span>
                                    @if (available)
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post">
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <button type="submit" class="btn btn-dark btn-sm add-to-cart-btn" title="Add to Cart">
                                                <i class="bi bi-bag-plus"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .product-card { transition: transform 0.2s; }
    .product-card:hover { transform: translateY(-4px); }
    .product-card:hover img { transform: scale(1.04); }
</style>

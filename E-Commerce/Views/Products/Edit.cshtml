@model E_Commerce.DTOs.CreateProductDto
@using E_Commerce.Models
@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Product</h4>
<hr />
<div class="row">
    <div class="col-md-4" >
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
           
            
            <div class="form-group">
                <label asp-for="ProductStatus" class="control-label"></label>
                <select asp-for="ProductStatus"
                        asp-items="Html.GetEnumSelectList<ProductStatus>()"
                        class="form-control"></select>
                <span asp-validation-for="ProductStatus" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label>Current Images</label>

                <div class="d-flex gap-3 flex-wrap">

                    @if (Model.ExistingImages != null)
                    {
                        foreach (var image in Model.ExistingImages)
                        {
                            <div>
                                <img src="@image.ImageUrl"
                                     width="120"
                                     height="120"
                                     style="object-fit:cover;border:1px solid #ccc;padding:5px;" />

                                <div class="mt-1">
                                    <input type="checkbox"
                                           name="DeletedImageIds"
                                           value="@image.Id" />

                                    <label>Delete</label>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Images" class="control-label"></label>
                <input asp-for="Images"
                       type="file"
                       multiple
                       accept=".jpg,.jpeg,.png,.webp"
                       class="form-control" />
                <span asp-validation-for="Images" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

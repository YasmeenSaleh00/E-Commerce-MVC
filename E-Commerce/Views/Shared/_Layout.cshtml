<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_Commerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Commerce.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/plugins.css" />
    <link rel="stylesheet" href="~/assets/css/style.css" />
    <link rel="stylesheet" href="~/assets/css/responsive.css" />
    <link rel="stylesheet" href="~/assets/css/font-awesome.css" />
    <link rel="stylesheet" href="~/assets/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/assets/css/themify-icons.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom mb-3">
            <div class="container-fluid d-flex justify-content-between align-items-center">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index" style="font-size: 24px; letter-spacing: 2px;">AVONE</a>

                <div class="header-icons d-flex align-items-center order-sm-last">

                    <div class="dropdown mx-2">
                        <a href="javascript:void(0);" class="text-dark" id="searchDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-search" style="font-size: 1.2rem;"></i>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end p-3 shadow-lg border-0" aria-labelledby="searchDropdown" style="min-width: 280px; border-radius: 8px;">
                            <form asp-controller="Products" asp-action="Index" method="get">
                                <div class="input-group">
                                    <input type="text" name="searchString" class="form-control form-control-sm" placeholder="Search..." aria-label="Search">
                                    <button class="btn btn-dark btn-sm" type="submit"><i class="bi bi-search"></i></button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="dropdown mx-2">
                        <a href="#" class="text-dark" id="gearDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-gear" style="font-size: 1.2rem;"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg p-3" aria-labelledby="gearDropdown" style="min-width: 220px;">
                            <li><h6 class="dropdown-header">Account Settings</h6></li>
                            <li><hr class="dropdown-divider"></li>
                            <partial name="_LoginPartial" />
                        </ul>
                    </div>

                    <a asp-controller="Wishlist" asp-action="Index" class="text-dark mx-1 mx-sm-2 position-relative">
                        <i class="bi bi-heart" style="font-size: 1.2rem;"></i>
                        <span class="badge rounded-circle bg-black text-white position-absolute top-0 start-100 translate-middle" style="font-size: 0.6rem;">0</span>
                    </a>

                    <a asp-controller="Cart" asp-action="Index" class="text-dark mx-1 mx-sm-2 position-relative">
                        <i class="bi bi-bag" style="font-size: 1.2rem;"></i>
                        <span class="badge rounded-circle bg-black text-white position-absolute top-0 start-100 translate-middle" style="font-size: 0.6rem;">2</span>
                    </a>

                    <button class="navbar-toggler ms-2 border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link text-uppercase fw-semibold text-dark px-3" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-uppercase fw-semibold text-dark px-3"  asp-controller="Categories" asp-action="Index">Categories</a></li>
                        <li class="nav-item"><a class="nav-link text-uppercase fw-semibold text-dark px-3" asp-controller="Products" asp-action="Index">Shop</a></li>
                        <li class="nav-item"><a class="nav-link text-uppercase fw-semibold text-dark px-3" href="#">About Us</a></li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="footer footer-1 border-top">
        <div class="footer-top pt-5 pb-4">
            <div class="container">
                <div class="row">
                    <div class="col-12 col-md-4 mb-4">
                        <h4 class="h6 fw-bold">CONTACT US</h4>
                        <p class="small mb-1">Amman, Jordan</p>
                        <p class="small mb-1"><b>Phone</b>: +962 000 0000</p>
                        <p class="small"><b>Email</b>: <a href="mailto:support@shop.com" class="text-decoration-none">support@shop.com</a></p>

                        <ul class="list-inline mt-3">
                            <li class="list-inline-item"><a href="#"><i class="bi bi-facebook text-dark"></i></a></li>
                            <li class="list-inline-item mx-2"><a href="#"><i class="bi bi-instagram text-dark"></i></a></li>
                            <li class="list-inline-item"><a href="#"><i class="bi bi-linkedin text-dark"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-12 col-md-4 mb-4">
                        <h4 class="h6 fw-bold">QUICK LINKS</h4>
                        <ul class="list-unstyled small">
                            <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a></li>
                            <li class="mb-2"><a asp-controller="Categories" asp-action="Index" class="text-decoration-none text-muted">Shop</a></li>

                            <li class="mb-2"><a asp-controller="Products" asp-action="Index" class="text-decoration-none text-muted">Shop</a></li>
                            <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">Privacy Policy</a></li>
                        </ul>
                    </div>

                    <div class="col-12 col-md-4">
                        <h4 class="h6 fw-bold">NEWSLETTER</h4>
                        <p class="small text-muted">Subscribe to get the latest updates.</p>
                        <form action="#" method="post">
                            <div class="input-group input-group-sm">
                                <input type="email" class="form-control" placeholder="Email address" required>
                                <button class="btn btn-dark" type="submit">Join</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-bottom py-3 border-top bg-light">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="copytext small text-muted">
                    &copy; @DateTime.Now.Year **AVONE**. All Rights Reserved.
                </div>
                <ul class="list-inline mb-0 h5">
                    <li class="list-inline-item"><i class="bi bi-credit-card"></i></li>
                    <li class="list-inline-item mx-2"><i class="bi bi-paypal"></i></li>
                </ul>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/assets/js/main.js" > </script>
    <script src="~/assets/js/plugins.js"> </script>
    <script src="~/assets/js/vendor/jquery-migrate-1.4.1.min.js"> </script>
    <script src="~/assets/js/vendor/jquery-min.js"> </script>
    <script src="~/assets/js/vendor/jquery.threesixty.min.js"> </script>
    <script src="~/assets/js/vendor/js.cookie.js"> </script>
    <script src="~/assets/js/vendor/photoswipe.min.js"> </script>
    <script src="assets/js/vendor/jquery-min.js"></script>
    <script src="assets/js/vendor/js.cookie.js"></script>
 

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

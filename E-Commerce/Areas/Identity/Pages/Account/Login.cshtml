@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div id="page-content">
    <div class="breadcrumbs-wrapper">
        <div class="container">
            <div class="breadcrumbs">
                <a asp-area="" asp-controller="Home" asp-action="Index" title="Back to the home page">Home</a>
                <span aria-hidden="true">|</span>
                <span>Login</span>
            </div>
        </div>
    </div>
    <div class="page-title text-center mb-5">
        <h1>Login</h1>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-12 col-sm-12 col-md-6 col-lg-6 box mb-4">
                <div class="p-4 border">
                    <h3>New Customers</h3>
                    <p>By creating an account with our store, you will be able to move through the checkout process faster, store multiple shipping addresses, view and track your orders in your account and more.</p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-dark">Create an account</a>
                </div>
            </div>

            <div class="col-12 col-sm-12 col-md-6 col-lg-6 box">
                <div class="mb-4 p-4 border">
                    <form id="account" method="post" class="contact-form">
                        <h3>Registered Customers</h3>
                        <p>If you have an account with us, please log in.</p>

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="row">
                            <div class="col-12">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.Email">Email <span class="required">*</span></label>
                                    <input asp-for="Input.Email" class="form-control" placeholder="example@mail.com" autocorrect="off" autocapitalize="off" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.Password">Password <span class="required">*</span></label>
                                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Enter your password" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12">
                                <div class="form-check custom-checkbox">
                                    <input class="form-check-input" asp-for="Input.RememberMe" />
                                    <label class="form-check-label ms-2" asp-for="Input.RememberMe">
                                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="text-left col-12">
                                <button id="login-submit" type="submit" class="btn btn-dark mb-3 w-100">Sign In</button>
                                <p class="mb-4 small">
                                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-muted">Forgot your password?</a> &nbsp; | &nbsp;
                                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-muted">Create account</a>
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

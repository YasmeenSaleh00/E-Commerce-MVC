@page
@model RegisterModel
@{
    ViewData["Title"] = "Create An Account";
}

<div id="page-content">
    <!--Breadcrumbs-->
    <div class="breadcrumbs-wrapper">
        <div class="container">
            <div class="breadcrumbs">
                <a asp-area="" asp-controller="Home" asp-action="Index" title="Back to the home page">Home</a>
                <span aria-hidden="true">|</span>
                <span>Create An Account</span>
            </div>
        </div>
    </div>
    <!--End Breadcrumbs-->
    <!--Page Title-->
    <div class="page-title text-center mb-5">
        <h1>Create An Account</h1>
    </div>
    <!--End Page Title-->

    <div class="container">
        <!--Main Content-->
        <div class="row justify-content-center">
            <div class="col-12 col-sm-12 col-md-10 col-lg-8 box">
                <div class="mb-4">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="contact-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <h3 class="mb-3">Personal Information</h3>
                        <div class="row">
                            <div class="col-12 col-sm-12 col-md-6 col-lg-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.FirstName">First Name <span class="required">*</span></label>
                                    <input asp-for="Input.FirstName" placeholder="Enter your first name" class="form-control" />
                                    <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6 col-lg-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.LastName">Last Name <span class="required">*</span></label>
                                    <input asp-for="Input.LastName" placeholder="Enter your last name" class="form-control" />
                                    <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-sm-12 col-md-6 col-lg-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.PhoneNumber">Phone Number <span class="required">*</span></label>
                                    <input asp-for="Input.PhoneNumber" placeholder="07XXXXXXXX" class="form-control" />
                                    <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6 col-lg-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.Gender">Gender <span class="required">*</span></label>
                                    <select asp-for="Input.Gender" class="form-control">
                                        <option value="">Select Gender</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                    </select>
                                    <span asp-validation-for="Input.Gender" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-sm-12 col-md-12 col-lg-12">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.Email">Email Address <span class="required">*</span></label>
                                    <input asp-for="Input.Email" placeholder="example@mail.com" class="form-control" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <h3 class="mt-4 mb-3">Login Information</h3>
                        <div class="row">
                            <div class="col-12 col-sm-12 col-md-6 col-lg-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.Password">Password <span class="required">*</span></label>
                                    <input asp-for="Input.Password" type="password" placeholder="Minimum 6 characters" class="form-control" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6 col-lg-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.ConfirmPassword">Confirm Password <span class="required">*</span></label>
                                    <input asp-for="Input.ConfirmPassword" type="password" placeholder="Repeat your password" class="form-control" />
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="text-left col-12 col-sm-12 col-md-6 col-lg-6">
                                <button id="registerSubmit" type="submit" class="btn btn-dark btn-lg mb-3 px-5">Submit</button>
                            </div>
                            <div class="text-right col-12 col-sm-12 col-md-6 col-lg-6 d-flex align-items-center justify-content-md-end">
                                <a asp-area="Identity" asp-page="/Account/Login" class="text-muted"><i class="bi bi-arrow-left"></i> Back To Login</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!--End Main Content-->
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}





@{
    ViewData["Title"] = "About Us";
}

<div class="row g-4">

    <!-- Hero Card -->
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #1a1a2e, #16213e); color: white;">
            <div class="card-body p-5 text-center">
                <i class="bi bi-controller" style="font-size: 4rem; color: var(--neon-primary);"></i>
                <h1 class="mt-3 fw-bold" style="letter-spacing: 3px;">CORE<span style="color:var(--neon-primary);">GAMING</span></h1>
                <p class="lead mt-2 text-white-50">Your ultimate destination for gaming gear, consoles, and accessories.</p>
            </div>
        </div>
    </div>

    <!-- Mission -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-rocket-takeoff-fill fs-2" style="color: var(--neon-primary);"></i>
                </div>
                <h5 class="fw-bold">Our Mission</h5>
                <p class="text-muted">
                    We exist to fuel the passion of every gamer — from casual players to hardcore enthusiasts —
                    by delivering the best products, unbeatable prices, and lightning-fast delivery.
                </p>
            </div>
        </div>
    </div>

    <!-- Vision -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-eye-fill fs-2" style="color: var(--neon-primary);"></i>
                </div>
                <h5 class="fw-bold">Our Vision</h5>
                <p class="text-muted">
                    To become the most trusted gaming e-commerce platform in the region,
                    known for authenticity, quality, and a community-first approach.
                </p>
            </div>
        </div>
    </div>

    <!-- Values -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-shield-fill-check fs-2" style="color: var(--neon-primary);"></i>
                </div>
                <h5 class="fw-bold">Our Values</h5>
                <ul class="text-muted ps-3">
                    <li>100% Authentic Products</li>
                    <li>Customer-First Support</li>
                    <li>Fast & Reliable Shipping</li>
                    <li>Secure Transactions</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">By the Numbers</h5>
                <div class="row text-center g-3">
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background:#f8f9fa;">
                            <h2 class="fw-bold" style="color:var(--neon-primary);">10K+</h2>
                            <p class="text-muted mb-0">Happy Gamers</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background:#f8f9fa;">
                            <h2 class="fw-bold" style="color:var(--neon-primary);">500+</h2>
                            <p class="text-muted mb-0">Products</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background:#f8f9fa;">
                            <h2 class="fw-bold" style="color:var(--neon-primary);">50+</h2>
                            <p class="text-muted mb-0">Brands</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background:#f8f9fa;">
                            <h2 class="fw-bold" style="color:var(--neon-primary);">24/7</h2>
                            <p class="text-muted mb-0">Support</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
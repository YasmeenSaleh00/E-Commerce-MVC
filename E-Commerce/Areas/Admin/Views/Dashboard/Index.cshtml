@model IEnumerable<E_Commerce.Models.Order>

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-cart-check fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Orders</div>
                    <div class="fw-bold fs-4">@ViewBag.TotalOrders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-currency-dollar fs-4 text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Revenue</div>
                    <div class="fw-bold fs-4">$@(((double)ViewBag.TotalRevenue).ToString("0.00"))</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-box-seam fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Products</div>
                    <div class="fw-bold fs-4">@ViewBag.TotalProducts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-people fs-4 text-info"></i>
                </div>
                <div>
                    <div class="text-muted small">Users</div>
                    <div class="fw-bold fs-4">@ViewBag.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
</div>

@if ((int)ViewBag.PendingOrders > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <span>You have <strong>@ViewBag.PendingOrders</strong> pending order(s) awaiting review.</span>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" asp-route-status="Pending" class="btn btn-sm btn-warning ms-auto">View Pending</a>
    </div>
}

<!-- Recent Orders -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0">Recent Orders</h6>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-dark">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">No orders yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Order #</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">#@order.Id</td>
                                <td>@order.ShippingFirstName @order.ShippingLastName</td>
                                <td>@order.OrderItems.Count item(s)</td>
                                <td>$@order.Total.ToString("0.00")</td>
                                <td>
                                    @{
                                        var badge = order.Status switch {
                                            E_Commerce.Models.OrderStatus.Pending => "bg-warning text-dark",
                                            E_Commerce.Models.OrderStatus.Processing => "bg-info text-dark",
                                            E_Commerce.Models.OrderStatus.Shipped => "bg-primary",
                                            E_Commerce.Models.OrderStatus.Delivered => "bg-success",
                                            E_Commerce.Models.OrderStatus.Cancelled => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badge">@order.Status</span>
                                </td>
                                <td class="text-muted small">@order.OrderDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-outline-secondary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

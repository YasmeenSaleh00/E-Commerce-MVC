@model IEnumerable<E_Commerce.Models.Order>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="display-5 fw-bold" style="color: var(--neon-primary); text-shadow: 0 0 10px var(--border-glow);">
            System Overview
        </h1>
        <p class="text-secondary">Real-time sales and logistics monitoring.</p>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="admin-card">
                <div class="d-flex align-items-center mb-2">
                    <div class="p-2 rounded me-3" style="background: rgba(255,193,7,0.1);">
                        <i class="bi bi-cart-fill text-warning" style="font-size:1.5rem;"></i>
                    </div>
                    <h6 class="mb-0 text-uppercase" style="color:var(--text-main); letter-spacing:1px;">Orders</h6>
                </div>
                <div class="d-flex justify-content-between align-items-end">
                    <h2 class="fw-bold mb-0" style="color:var(--text-main);">@ViewBag.TotalOrders</h2>
                    @if ((int)ViewBag.PendingOrders > 0)
                    {
                        <span class="badge border border-warning text-warning" style="font-size:0.7rem;">
                            @ViewBag.PendingOrders pending
                        </span>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card">
                <div class="d-flex align-items-center mb-2">
                    <div class="p-2 rounded me-3" style="background: rgba(0,242,255,0.1);">
                        <i class="bi bi-currency-dollar" style="font-size:1.5rem; color:var(--neon-primary);"></i>
                    </div>
                    <h6 class="mb-0 text-uppercase" style="color:var(--text-main); letter-spacing:1px;">Revenue</h6>
                </div>
                <h2 class="fw-bold mb-0" style="color:var(--text-main);">$@(((double)ViewBag.TotalRevenue).ToString("0.00"))</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card">
                <div class="d-flex align-items-center mb-2">
                    <div class="p-2 rounded me-3" style="background: rgba(112,0,255,0.1);">
                        <i class="bi bi-box-seam" style="font-size:1.5rem; color:var(--neon-secondary);"></i>
                    </div>
                    <h6 class="mb-0 text-uppercase" style="color:var(--text-main); letter-spacing:1px;">Products</h6>
                </div>
                <h2 class="fw-bold mb-0" style="color:var(--text-main);">@ViewBag.TotalProducts</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card">
                <div class="d-flex align-items-center mb-2">
                    <div class="p-2 rounded me-3" style="background: rgba(0,242,255,0.08);">
                        <i class="bi bi-people" style="font-size:1.5rem; color:var(--neon-primary);"></i>
                    </div>
                    <h6 class="mb-0 text-uppercase" style="color:var(--text-main); letter-spacing:1px;">Users</h6>
                </div>
                <h2 class="fw-bold mb-0" style="color:var(--text-main);">@ViewBag.TotalUsers</h2>
            </div>
        </div>
    </div>

    @if ((int)ViewBag.PendingOrders > 0)
    {
        <div class="mb-4 p-3 rounded" style="background:rgba(255,193,7,0.08); border:1px solid rgba(255,193,7,0.3);">
            <span style="color:#ffc107;"><i class="bi bi-exclamation-triangle me-2"></i>
            <strong>@ViewBag.PendingOrders</strong> pending order(s) awaiting review.</span>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" asp-route-status="Pending"
               class="btn btn-sm btn-neon ms-3">View Pending</a>
        </div>
    }

    <!-- Recent Orders Table -->
    <div class="admin-card p-0 overflow-hidden">
        <div class="d-flex justify-content-between align-items-center p-3" style="border-bottom:1px solid rgba(255,255,255,0.08);">
            <h5 class="mb-0 text-white"><i class="bi bi-lightning-charge me-2" style="color:var(--neon-primary);"></i>Recent Orders</h5>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-neon">View All</a>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-secondary">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">No orders yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                    <thead style="background:rgba(0,0,0,0.3);">
                        <tr class="text-secondary border-bottom" style="border-color:rgba(255,255,255,0.08)!important;">
                            <th class="ps-4">Order #</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            var badgeCss = order.Status switch {
                                E_Commerce.Models.OrderStatus.Pending    => "border border-warning text-warning",
                                E_Commerce.Models.OrderStatus.Processing => "border border-info text-info",
                                E_Commerce.Models.OrderStatus.Shipped    => "btn-neon",
                                E_Commerce.Models.OrderStatus.Delivered  => "border border-success text-success",
                                E_Commerce.Models.OrderStatus.Cancelled  => "border border-danger text-danger",
                                _                                        => "border border-secondary text-secondary"
                            };
                            <tr style="border-color:rgba(255,255,255,0.06)!important;">
                                <td class="ps-4 fw-bold" style="color:var(--neon-primary);">#@order.Id</td>
                                <td>@order.ShippingFirstName @order.ShippingLastName</td>
                                <td>@order.OrderItems.Count</td>
                                <td>$@order.Total.ToString("0.00")</td>
                                <td><span class="badge @badgeCss" style="font-size:0.72rem;">@order.Status</span></td>
                                <td class="text-secondary small">@order.OrderDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td class="text-end pe-4">
                                    <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-outline-light px-3">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

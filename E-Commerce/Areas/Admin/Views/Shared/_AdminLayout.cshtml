<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/E_Commerce.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <nav class="sidebar d-none d-md-block">
            <div class="p-4 text-center">
                <h4 style="color: var(--neon-primary); letter-spacing: 2px;">CORE_ADMIN</h4>
            </div>
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-controller me-2"></i> Categories
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">
                        <i class="bi bi-box-seam me-2"></i> Products
                    </a>
                </li> 
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                        <i class="bi bi-cart-check me-2"></i> Orders 
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Testimonials" asp-action="Index">
                        <i class="bi bi-chat-quote me-2"></i> Testimonials
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Pages" asp-action="About">
                        <i class="bi bi-info-circle me-2"></i> About Us
                    </a>
                </li> 
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Pages" asp-action="Privacy">
                        <i class="bi bi-shield-lock me-2"></i> Privacy & Policy
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Main Content -->
        <main role="main" class="flex-grow-1" style="margin-left: 250px; padding: 30px;">
            <header class="mb-4 d-flex justify-content-between align-items-center">
                <h2 class="text-white">@ViewData["Title"]</h2>
                <div>
                <div class="dropdown mx-2">
                    <a href="#" class="text-dark" id="gearDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-gear" style="font-size: 1.2rem;"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg p-3" aria-labelledby="gearDropdown" style="min-width: 220px;">
                        <li><h6 class="dropdown-header">Account Settings</h6></li>
                        <li><hr class="dropdown-divider"></li>
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
                <div class="user-profile">
                    <span class="badge rounded-pill btn-neon p-2">Admin Active</span>
                </div>
                </div>
            </header>

            <div class="container">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
           
            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
            <script src="~/js/site.js" asp-append-version="true"></script>
           


            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

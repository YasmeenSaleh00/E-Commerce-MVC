@model E_Commerce.DTOs.CreateProductDto
@using E_Commerce.Models

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container-fluid">
    <a asp-action="Index" class="btn btn-sm btn-outline-light mb-4"><i class="bi bi-arrow-left me-1"></i>Back</a>

    <div class="admin-card">
        <h5 class="text-white mb-4">Edit Product</h5>
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="mb-3 p-3 rounded" style="background:rgba(220,53,69,0.15); border:1px solid rgba(220,53,69,0.4); color:#ff6b6b;"></div>
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label text-secondary">Product Name</label>
                    <input asp-for="Name" class="form-control admin-input" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CategoryId" class="form-label text-secondary">Category</label>
                    <select asp-for="CategoryId" class="form-select admin-input" asp-items="ViewBag.Categories">
                        <option value="">-- Select Category --</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label text-secondary">Description</label>
                    <textarea asp-for="Description" class="form-control admin-input" rows="3"></textarea>
                </div>
                <div class="col-md-4">
                    <label asp-for="Price" class="form-label text-secondary">Price ($)</label>
                    <input asp-for="Price" class="form-control admin-input" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Quantity" class="form-label text-secondary">Stock Quantity</label>
                    <input asp-for="Quantity" class="form-control admin-input" type="number" min="0" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ProductStatus" class="form-label text-secondary">Status</label>
                    <select asp-for="ProductStatus" asp-items="Html.GetEnumSelectList<ProductStatus>()" class="form-select admin-input"></select>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                        <label asp-for="IsFeatured" class="form-check-label text-secondary">Feature on homepage</label>
                    </div>
                </div>

                @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                {
                    <div class="col-12">
                        <label class="form-label text-secondary">Current Images</label>
                        <div class="d-flex gap-3 flex-wrap">
                            @foreach (var image in Model.ExistingImages)
                            {
                                <div class="text-center">
                                    <img src="@image.ImageUrl" width="90" height="90"
                                         style="object-fit:cover;border-radius:8px;border:1px solid rgba(255,255,255,0.15);" />
                                    <div class="mt-1 form-check">
                                        <input type="checkbox" name="DeletedImageIds" value="@image.Id"
                                               class="form-check-input" id="del_@image.Id" />
                                        <label class="form-check-label small" style="color:#ff6b6b;" for="del_@image.Id">Delete</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="col-12">
                    <label asp-for="Images" class="form-label text-secondary">Add New Images</label>
                    <input asp-for="Images" type="file" multiple accept=".jpg,.jpeg,.png,.webp" class="form-control admin-input" />
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-neon px-4">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
